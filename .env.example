# OpenRouter API Key for AI Vision models
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Public URL of the app (used in OpenRouter headers)
NEXT_PUBLIC_APP_URL=https://slideforge.app

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER-SIDE ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Email access control (fallback when Supabase is not configured) ───────────
# Comma-separated list of emails authorized to use the app
# Only used when SUPABASE_SERVICE_ROLE_KEY is not set
ALLOWED_EMAILS=user@example.com,another@example.com
